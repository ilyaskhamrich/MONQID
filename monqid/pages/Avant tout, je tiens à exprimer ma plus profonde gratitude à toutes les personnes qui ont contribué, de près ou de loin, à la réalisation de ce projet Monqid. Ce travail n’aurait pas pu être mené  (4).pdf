    <dc:title>
      <rdf:Alt>
        <rdf:li xml:lang="x-default">Avant tout, je tiens à exprimer ma plus profonde gratitude à toutes les personnes qui ont contribué, de près ou de loin, à la réalisation de ce projet "Monqid". Ce travail n’aurait pas pu être mené à bien sans le soutien, les conseils et l’accompagnement</rdf:li>
        <rdf:li xml:lang="fr-FR">Avant tout, je tiens à exprimer ma plus profonde gratitude à toutes les personnes qui ont contribué, de près ou de loin, à la réalisation de ce projet "Monqid". Ce travail n’aurait pas pu être mené à bien sans le soutien, les conseils et l’accompagnement</rdf:li>
      </rdf:Alt>
    </dc:title>
  </rdf:Description>
</rdf:RDF>
                                                                                                    
                                                                                                    
                                                                                                    
                                                                                                    
                                                                                                    
                                                                                                    
                                                                                                    
                                                                                                    
                                                                                                    
                                                                                                    
                                                                                                    
                                                                                                    
                                                                                                    
                                                                                                    
                                                                                                    
                                                                                                    
                                                                                                    
                                                                                                    
                                                                                                    
                                                                                                    
                           
